      <circle cx="160" cy="40" r="3" fill="#00FFFF" />
      <circle cx="40" cy="140" r="3" fill="#00FFFF" />
      <circle cx="160" cy="160" r="3" fill="#00FFFF" />
    </g>

    <!-- Llama head silhouette (simplified, geometric) -->
    <g filter="url(#neon-glow)">
      <!-- Llama head outline -->
      <ellipse cx="100" cy="90" rx="35" ry="45" fill="url(#llama-gradient)" opacity="0.9"/>

      <!-- Ears -->
      <ellipse cx="85" cy="55" rx="8" ry="20" fill="url(#llama-gradient)" transform="rotate(-20 85 55)"/>
      <ellipse cx="115" cy="55" rx="8" ry="20" fill="url(#llama-gradient)" transform="rotate(20 115 55)"/>

      <!-- Snout -->
      <ellipse cx="100" cy="110" rx="18" ry="14" fill="url(#llama-gradient)"/>

      <!-- Nostrils -->
      <circle cx="94" cy="110" r="3" fill="#0a0a0f"/>
      <circle cx="106" cy="110" r="3" fill="#0a0a0f"/>
    </g>

    <!-- Cyber eyes with glow -->
    <g filter="url(#neon-glow)">
      <!-- Left eye -->
      <ellipse cx="90" cy="85" rx="6" ry="8" fill="#0a0a0f"/>
      <circle cx="90" cy="85" r="4" fill="#00FFFF">
        <animate attributeName="r" values="4;3;4" dur="2s" repeatCount="indefinite" />
      </circle>

      <!-- Right eye -->
      <ellipse cx="110" cy="85" rx="6" ry="8" fill="#0a0a0f"/>
      <circle cx="110" cy="85" r="4" fill="#00FFFF">
        <animate attributeName="r" values="4;3;4" dur="2s" repeatCount="indefinite" />
      </circle>
    </g>

    <!-- Cybernetic implants/accents -->
    <g stroke="url(#cyber-gradient)" stroke-width="2" fill="none" filter="url(#neon-glow)">
      <!-- Forehead circuit -->
      <path d="M90 70 L100 65 L110 70" />
      <circle cx="100" cy="65" r="2" fill="#9333EA"/>

      <!-- Cheek accents -->
      <path d="M75 95 L85 95" />
      <path d="M115 95 L125 95" />
    </g>

    <!-- Text "ig" at top, "llama" at bottom -->
    <text x="100" y="35" text-anchor="middle" fill="#FFA500" font-size="14" font-weight="bold" font-family="monospace" filter="url(#neon-glow)">
      ig
    </text>
    <text x="100" y="175" text-anchor="middle" fill="#00FFFF" font-size="10" font-family="monospace" filter="url(#neon-glow)">
      LLAMA
