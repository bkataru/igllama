      </linearGradient>
    </defs>

    <!-- Background circle with gradient -->
    <circle cx="100" cy="100" r="95" fill="#0a0a0f" stroke="#FFA500" stroke-width="2">
      <animate attributeName="stroke" values="#FFA500;#00FFFF;#9333EA;#FFA500" dur="4s" repeatCount="indefinite" />
