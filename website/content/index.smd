      <linearGradient id="llama-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#FFA500;stop-opacity:1" />
        <stop offset="50%" style="stop-color:#FF6B00;stop-opacity:1" />
